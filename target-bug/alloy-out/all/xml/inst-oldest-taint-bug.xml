<!-- opstate: every operand maps to its state flavour.
     Reg_s$0 → rax  (Ra, Rc, Rd; branch conditions; free addresses)
     Reg_s$1 → rcx  (Rb only: load_B output and add's Rb input)
     This gives the bug: load_A taints rax, load_B taints rcx; the add's
     getOldestTaint picks load_A (older seqNum); when load_A commits,
     rax taint is freed and load[Rc] fires even though rcx (Rb) is still
     speculative. -->
<field label="opstate" ID="39" parentID="38">
   <!-- Reg_s$0 (rax): Ra, Rc, Rd, branch conditions, free addresses -->
   <tuple> <atom label="Outreg$0"/>  <atom label="Reg_s$0"/> </tuple>  <!-- Ra -->
   <tuple> <atom label="Outreg$2"/>  <atom label="Reg_s$0"/> </tuple>  <!-- Rc = add out -->
   <tuple> <atom label="Outreg$3"/>  <atom label="Reg_s$0"/> </tuple>  <!-- Rd = xm out -->
   <tuple> <atom label="Inreg$0"/>   <atom label="Reg_s$0"/> </tuple>  <!-- branch_inner cond = Ra -->
   <tuple> <atom label="Inreg$1"/>   <atom label="Reg_s$0"/> </tuple>  <!-- add in0 = Ra -->
   <tuple> <atom label="Inreg$3"/>   <atom label="Reg_s$0"/> </tuple>  <!-- branch_outer cond -->
   <tuple> <atom label="Inaddr$0"/>  <atom label="Reg_s$0"/> </tuple>  <!-- load_A addr (free) -->
   <tuple> <atom label="Inaddr$1"/>  <atom label="Reg_s$0"/> </tuple>  <!-- load_B addr (free) -->
   <tuple> <atom label="Inaddr$2"/>  <atom label="Reg_s$0"/> </tuple>  <!-- load[Rc] addr = Rc -->
   <!-- Reg_s$1 (rcx): Rb only -->
   <tuple> <atom label="Outreg$1"/>  <atom label="Reg_s$1"/> </tuple>  <!-- Rb = load_B out -->
   <tuple> <atom label="Inreg$2"/>   <atom label="Reg_s$1"/> </tuple>  <!-- add in1 = Rb -->
   <!-- Mem_s$0 -->
   <tuple> <atom label="Inmem$0"/>   <atom label="Mem_s$0"/> </tuple>
   <tuple> <atom label="Inmem$1"/>   <atom label="Mem_s$0"/> </tuple>
   <tuple> <atom label="Inmem$2"/>   <atom label="Mem_s$0"/> </tuple>
   <types> <type ID="38"/> <type ID="8"/> </types>
</field>

<!-- rf: reads-from edges (output operand → input operand, same state type)
