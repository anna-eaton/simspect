   <tuple> <atom label="Outreg$2"/> <atom label="Inaddr$2"/> </tuple>
   <types> <type ID="38"/> <type ID="38"/> </types>
</field>

<!-- ddi: intra-instruction data-dependency edges (input → output)
     load_A:   Inmem$0  → Outreg$0  (memory → Ra)
